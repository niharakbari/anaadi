# Server Port configuration
PORT=3200

# AI Model Configuration
AI_MODEL=openclip

# Client origin for CORS configurations
CLIENT_ORIGIN=http://localhost:5173

# Database configuration settings
DB_HOST=127.0.0.1
DB_USER=root
DB_NAME=imaginary
DB_PASSWORD=your_database_password

# File upload directories and batch constraints
MAX_FILES_PER_UPLOAD=100
DESIGN_LIBRARY_DIRECTORY=uploads/design_library
QUERY_UPLOAD_DIRECTORY=uploads/query_uploads

# JWT session configuration
JWT_SECRET=your_jwt_signing_secret_key
JWT_EXPIRES_IN=1d

# Admin user bootstrap credentials
ADMIN_EMAIL=admin@anaadi.com
ADMIN_PASSWORD=your_secure_admin_password_placeholder